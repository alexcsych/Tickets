<UserControl x:Class="Tickets.Views.TicketsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Tickets.ViewModels"
        xmlns:i="clr-namespace:Tickets.Infrastructure">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Command="{Binding OpenProfileCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    ToolTip="Мій профіль" 
                    VerticalAlignment="Center"
                    Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Account" VerticalAlignment="Center" />
                    <TextBlock Text="Профіль" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="1" 
                    Command="{Binding OpenRoutesCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    ToolTip="Перегляд рейсів" 
                    VerticalAlignment="Center"
                    Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plane" VerticalAlignment="Center" />
                    <TextBlock Text="Рейси" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <materialDesign:Card Grid.Column="2" Margin="10" Padding="15" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <TextBox Width="180" Margin="10,0"
                             materialDesign:HintAssist.Hint="Звідки"
                             Text="{Binding From, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    <TextBox Width="180" Margin="10,0"
                             materialDesign:HintAssist.Hint="Куди"
                             Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    <TextBox Width="180" Margin="10,0"
                             materialDesign:HintAssist.Hint="Модель автобуса"
                             Text="{Binding BusModel, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    <ToggleButton IsChecked="{Binding IsAscending}"
                                  Margin="10,0"
                                  Style="{StaticResource MaterialDesignActionToggleButton}"
                                  ToolTip="Сортування за ціною">
                        <materialDesign:ToggleButtonAssist.OnContent>
                            <materialDesign:PackIcon Kind="SortNumericAscending" />
                        </materialDesign:ToggleButtonAssist.OnContent>
                        <materialDesign:PackIcon Kind="SortNumericDescending" />
                    </ToggleButton>

                    <Button Command="{Binding SearchCommand}"
                            Margin="20,0,10,0"
                            Content="{materialDesign:PackIcon Kind=Magnify}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="Шукати рейси" />

                    <Button Command="{Binding SearchCommand}" 
                            CommandParameter="Clear"
                            Margin="10,0"
                            Content="{materialDesign:PackIcon Kind=Refresh}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="Скинути фільтри" />
                </StackPanel>
            </materialDesign:Card>

            <Button Grid.Column="3" 
                    Command="{Binding LogOutCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    ToolTip="Вийти з аккаунта" 
                    VerticalAlignment="Center"
                    Margin="0,0,0,0"
                    Background="white">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Logout" VerticalAlignment="Center" />
                    <TextBlock Text="Вихід" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        <ListBox Grid.Row="1" ItemsSource="{Binding VisibleTickets}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Center">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Margin="8" Padding="16" Width="900">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column = "0" VerticalAlignment="Center" Background="Transparent" ToolTip="Маршрут рейсу">
                                <TextBlock Text="{Binding Route.From}" FontWeight="Bold" FontSize="16"/>
                                <materialDesign:PackIcon Kind="ArrowDownward" HorizontalAlignment="Left" Foreground="Gray"/>
                                <TextBlock Text="{Binding Route.To}" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0" Background="Transparent" ToolTip="Дата та час рейсу">
                                <TextBlock Text="{Binding Route.DepartureTime, StringFormat=\{0:dd.MM.yyyy\}}" />
                                <TextBlock Text="{Binding Route.DepartureTime, StringFormat=\{0:HH:mm\}}" FontWeight="Light"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Background="Transparent" ToolTip="Дата та час купівлі квитка">
                                <TextBlock Text="{Binding PurchaseDate, StringFormat=\{0:dd.MM.yyyy\}}" />
                                <TextBlock Text="{Binding PurchaseDate, StringFormat=\{0:HH:mm\}}" FontWeight="Light"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Background="Transparent" ToolTip="Модель та номер автобусу">
                                <TextBlock Text="{Binding Route.Bus.Model}" />
                                <TextBlock Text="{Binding Route.Bus.Number}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>

                            <Button Grid.Column="4" 
                                    Command="{Binding DataContext.ReturnTicketCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Content="{Binding Route.Price}"
                                    ContentStringFormat="{}Повернути {0} грн"
                                    Style="{StaticResource MaterialDesignRaisedButton}" />
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
