<UserControl x:Class="Tickets.Views.AdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="clr-namespace:Tickets.Infrastructure"
             xmlns:vm="clr-namespace:Tickets.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <materialDesign:ColorZone Mode="PrimaryMid" Padding="16" Grid.Row="0">
            <Grid>
                <Button HorizontalAlignment="Left" Command="{Binding LogOutCommand}" 
                        Content="{materialDesign:PackIcon Kind=ArrowLeft}" 
                        Style="{StaticResource MaterialDesignIconButton}" Foreground="White"/>

                <TextBlock Text="Панель Адміністратора" HorizontalAlignment="Center" 
                           VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
            </Grid>
        </materialDesign:ColorZone>

        <StackPanel Grid.Row="1" Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Оберіть таблицю:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Tables}" 
                          SelectedItem="{Binding SelectedTable}" 
                          Width="200"
                          Style="{StaticResource MaterialDesignFilledComboBox}"/>
            </StackPanel>

            <materialDesign:Card>
                <DataGrid ItemsSource="{Binding CurrentData}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="True" 
                          MaxHeight="500"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          VerticalScrollBarVisibility="Auto">
                </DataGrid>
            </materialDesign:Card>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding DeleteCommand}" 
            CommandParameter="{Binding SelectedItem}"
            Content="ВИДАЛИТИ ВИБРАНЕ" 
            Margin="10" Background="Red" BorderBrush="Red"
            Style="{StaticResource MaterialDesignRaisedButton}"/>

            <Button Command="{Binding SaveChangesCommand}" 
            Content="ЗБЕРЕГТИ ЗМІНИ В БД" 
            Margin="10"
            Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
