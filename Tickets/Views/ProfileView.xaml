<Window x:Class="Tickets.Views.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Tickets.ViewModels"
        xmlns:i="clr-namespace:Tickets.Infrastructure"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Профіль" Height="700" Width="600" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:ProfileViewModel />
    </Window.DataContext>

    <Grid Background="#ffdadada">
        <Border MinWidth="400" Margin="15" Background="White" VerticalAlignment="Center" Padding="30" MaxWidth="400" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="LightGray" ShadowDepth="0" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Профіль" TextAlignment="Center" FontSize="30" FontWeight="Bold" Margin="0 0 0 20" />

                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     materialDesign:HintAssist.Hint="Ваше ім'я" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                     Margin="0 0 0 30"/>

                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     materialDesign:HintAssist.Hint="Ваше прізвище" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                     Margin="0 0 0 30"/>

                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     materialDesign:HintAssist.Hint="Введіть пошту" 
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                     Margin="0 0 0 30"/>

                <Button Content="Змінити дані профілю"
                    Command="{Binding UpdateProfileCommand}"
                    Margin="0 0 0 30"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>

                <PasswordBox materialDesign:HintAssist.Hint="Введіть пароль" 
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                         Margin="0 0 0 30"
                         i:PasswordHelper.Attach="True"
                         i:PasswordHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <PasswordBox materialDesign:HintAssist.Hint="Введіть пароль знову" 
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                         Margin="0 0 0 30"
                         i:PasswordHelper.Attach="True"
                         i:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <Button Content="Змінити пароль" 
                    Command="{Binding ChangePasswordCommand}"
                    Margin="0 0 0 10" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>

                <Button Content="Повернутися" 
                    Command="{Binding OpenRoutesCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignFlatButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
