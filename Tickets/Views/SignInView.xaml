<Window x:Class="Tickets.Views.SignInView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Tickets.ViewModels"
        xmlns:i="clr-namespace:Tickets.Infrastructure"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Реєстрація нового аккаунту" Height="600" Width="600" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:SignInViewModel />
    </Window.DataContext>

    <Grid Background="#ffdadada">
        <Border MinWidth="400" Margin="15" Background="White" VerticalAlignment="Center" Padding="30" MaxWidth="400" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="LightGray" ShadowDepth="0" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Реєстрація" TextAlignment="Center" FontSize="30" FontWeight="Bold" Margin="0 0 0 20" />

                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         materialDesign:HintAssist.Hint="Введіть ім'я" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0 0 0 30"/>

                <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         materialDesign:HintAssist.Hint="Введіть прізвище" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0 0 0 30"/>

                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         materialDesign:HintAssist.Hint="Введіть пошту" 
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                         Margin="0 0 0 30"/>

                <PasswordBox materialDesign:HintAssist.Hint="Введіть пароль" 
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0 0 0 30"
                             i:PasswordHelper.Attach="True"
                             i:PasswordHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <PasswordBox materialDesign:HintAssist.Hint="Введіть пароль знову" 
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" 
                             Margin="0 0 0 30"
                             i:PasswordHelper.Attach="True"
                             i:PasswordHelper.Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <Button Content="Зареєструватися" 
                        Command="{Binding RegistrationCommand}"
                        Margin="0 10 0 10" 
                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                <Button Content="Вже є аккаунт?" 
                        Command="{Binding OpenLogInCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource MaterialDesignFlatButton}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>