<Window x:Class="Tickets.Views.RoutesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Tickets.ViewModels"
        xmlns:i="clr-namespace:Tickets.Infrastructure"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Рейси" Height="500" Width="1000" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:RoutesViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Margin="10" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <TextBox Width="180" Margin="10,0"
                     materialDesign:HintAssist.Hint="Звідки"
                     Text="{Binding From, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                <TextBox Width="180" Margin="10,0"
                     materialDesign:HintAssist.Hint="Куди"
                     Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                <TextBox Width="180" Margin="10,0"
                     materialDesign:HintAssist.Hint="Модель автобуса"
                     Text="{Binding BusModel, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                
                <ToggleButton IsChecked="{Binding IsAscending}"
                  Margin="10,0"
                  Style="{StaticResource MaterialDesignActionToggleButton}"
                  ToolTip="Сортування за ціною">
                    <materialDesign:ToggleButtonAssist.OnContent>
                        <materialDesign:PackIcon Kind="SortNumericAscending" />
                    </materialDesign:ToggleButtonAssist.OnContent>
                    <materialDesign:PackIcon Kind="SortNumericDescending" />
                </ToggleButton>

                <Button Command="{Binding SearchCommand}"
                    Margin="20,0,10,0"
                    Content="{materialDesign:PackIcon Kind=Magnify}"
                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                    ToolTip="Шукати рейси" />

                <Button Command="{Binding SearchCommand}" 
                    CommandParameter="Clear"
                    Margin="5,0"
                    Content="{materialDesign:PackIcon Kind=Refresh}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    ToolTip="Скинути фільтри" />
            </StackPanel>
        </materialDesign:Card>
        <ListBox Grid.Row="1" ItemsSource="{Binding VisibleRoutes}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Center">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <materialDesign:Card Margin="8" Padding="16" Width="900">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column = "0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding From}" FontWeight="Bold" FontSize="16"/>
                                <materialDesign:PackIcon Kind="ArrowDownward" HorizontalAlignment="Left" Foreground="Gray"/>
                                <TextBlock Text="{Binding To}" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding DepartureTime, StringFormat=\{0:dd.MM.yyyy\}}" />
                                <TextBlock Text="{Binding DepartureTime, StringFormat=\{0:HH:mm\}}" FontWeight="Light"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Bus.Model}" />
                                <TextBlock Text="{Binding Bus.Number}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Зайнято місць:" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock FontWeight="Bold" FontSize="14" HorizontalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} / {1}">
                                            <Binding Path="Tickets.Count" />
                                            <Binding Path="Bus.Capacity" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Column="4" 
                                Command="{Binding DataContext.BuyTicketCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                Content="{Binding Price}"
                                ContentStringFormat="{}Купити за {0} грн"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                        </Grid>
                    </materialDesign:Card>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
